<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-6">
  <div>
    <h1 class="text-3xl font-headline font-black tracking-tighter text-[#fafafa] mb-2">Visão Geral</h1>
    <p class="text-sm text-[#a1a1aa] font-body">Acompanhe seu progresso de estudo e métricas recentes.</p>
  </div>
  <div class="flex items-center gap-2 text-sm text-[#71717a] border border-[#27272a] rounded-lg px-3 py-1.5 bg-[#09090b]">
    <span class="material-symbols-outlined text-[16px]">calendar_today</span>
    <span>Sincronizado: Agora mesmo</span>
  </div>
</div>

<!-- Subjects Grid -->
<section class="mb-8">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-lg font-headline font-bold text-[#fafafa] tracking-tight">Matérias Ativas</h2>
    <a class="text-sm font-medium text-[#a78bfa] hover:text-[#c4b5fd] transition-colors flex items-center gap-1" href="<%= subjects_path %>">
      Ver Todas <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
    </a>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% if @subjects.empty? %>
      <div class="col-span-full text-center py-12 bg-[#121215] border border-[#27272a] rounded-xl">
        <span class="material-symbols-outlined text-4xl text-[#27272a] mb-2">folder_off</span>
        <p class="text-[#a1a1aa]">Nenhuma matéria cadastrada.</p>
      </div>
    <% else %>
      <% @subjects.each do |subject| %>
        <%= link_to questions_path(subject_id: subject.id), class: "group relative bg-[#121215] border border-[#27272a] rounded-xl p-6 hover:bg-[#18181b] hover:border-[#52525b] transition-all duration-300 cursor-pointer flex flex-col h-full block" do %>
          <div class="absolute inset-0 bg-gradient-to-br to-transparent opacity-0 group-hover:opacity-10 transition-opacity rounded-xl pointer-events-none" style="--tw-gradient-from: <%= subject.color || '#a78bfa' %>; --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, transparent);"></div>
          <div class="flex justify-between items-start mb-4">
            <div class="w-12 h-12 rounded-lg bg-[#09090b] border border-[#27272a] flex items-center justify-center group-hover:scale-105 transition-transform shadow-sm" style="color: <%= subject.color || '#a78bfa' %>;">
              <% if subject.icon.present? && subject.icon.length <= 2 %>
                <span class="text-2xl"><%= subject.icon %></span>
              <% else %>
                <span class="material-symbols-outlined text-2xl" style="font-variation-settings: 'FILL' 1;"><%= subject.icon.presence || 'schema' %></span>
              <% end %>
            </div>
            <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-[#1e1e22] text-[#a1a1aa]">
              Active
            </span>
          </div>
          <div class="mt-auto">
            <h3 class="text-lg font-headline font-bold text-[#fafafa] mb-1 transition-colors" style="--tw-group-hover-color: <%= subject.color || '#c4b5fd' %>;"><span class="group-hover:!text-[var(--tw-group-hover-color)] transition-colors"><%= subject.name %></span></h3>
            <div class="flex items-center justify-between mt-4 border-t border-[#27272a] pt-4">
              <div class="flex flex-col">
                <span class="text-xs font-label text-[#71717a] uppercase tracking-wider mb-0.5">Novas</span>
                <span class="text-sm font-bold text-[#fafafa]"><%= subject.questions.count { |q| q.times_answered == 0 } %></span>
              </div>
              <div class="flex flex-col text-center">
                <span class="text-xs font-label text-[#71717a] uppercase tracking-wider mb-0.5">Respondidas</span>
                <span class="text-sm font-bold text-[#fafafa]"><%= subject.questions.count { |q| q.times_answered > 0 } %></span>
              </div>
              <div class="flex flex-col text-right">
                <span class="text-xs font-label text-[#71717a] uppercase tracking-wider mb-0.5">Total</span>
                <span class="text-sm font-bold text-[#a1a1aa]"><%= subject.questions.size %></span>
              </div>
            </div>
            <div class="flex items-center justify-between mt-4 border-t border-[#27272a] pt-4">
              <div class="flex flex-col">
                <span class="text-xs font-label text-[#71717a] uppercase tracking-wider mb-0.5">Criada em</span>
                <span class="text-sm font-medium text-[#a1a1aa]"><%= subject.created_at.in_time_zone('America/Sao_Paulo').strftime("%d/%m/%y") %></span>
              </div>
              <div class="flex flex-col text-right">
                <span class="text-xs font-label text-[#71717a] uppercase tracking-wider mb-0.5">Estudada pela ultima vez:</span>
                <% last_answered = subject.questions.map(&:last_answered_at).compact.max %>
                <span class="text-sm font-medium text-[#a1a1aa]"><%= last_answered ? last_answered.in_time_zone('America/Sao_Paulo').strftime("%d/%m/%y às %H:%M") : "Nunca" %></span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
</section>

<!-- Recent Activity List -->
<section>
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-lg font-headline font-bold text-[#fafafa] tracking-tight">Simulados Recentes</h2>
    <button class="w-8 h-8 rounded border border-[#27272a] flex items-center justify-center text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#121215] transition-colors">
      <span class="material-symbols-outlined text-[18px]">filter_list</span>
    </button>
  </div>
  
  <div class="flex flex-col gap-3">
    <% if @recent_activities.empty? %>
      <div class="text-center py-8 bg-[#09090b] border border-[#27272a] rounded-lg">
        <p class="text-[#a1a1aa]">Nenhuma atividade recente.</p>
      </div>
    <% else %>
      <% @recent_activities.each do |activity| %>
        <% if activity.is_a?(Exam) %>
          <% score = (activity.correct_count.to_f / activity.questions_count * 100).round %>
          <%= link_to exam_path(activity), class: "group flex items-center justify-between p-4 bg-[#09090b] border border-[#27272a] rounded-lg hover:bg-[#121215] transition-colors cursor-pointer block" do %>
            <div class="flex items-center gap-4">
              <% if score >= 70 %>
                <div class="w-10 h-10 rounded bg-[#065f46]/10 border border-[#065f46] flex items-center justify-center text-[#34d399]">
                  <span class="material-symbols-outlined text-[20px]">check_circle</span>
                </div>
              <% else %>
                <div class="w-10 h-10 rounded bg-[#18181b] border border-[#52525b] flex items-center justify-center text-[#a1a1aa]">
                  <span class="material-symbols-outlined text-[20px]">article</span>
                </div>
              <% end %>
              <div>
                <h4 class="text-sm font-bold text-[#fafafa]"><%= activity.subject.name %></h4>
                <p class="text-xs text-[#a1a1aa] mt-0.5">Simulado · <%= activity.updated_at.in_time_zone('America/Sao_Paulo').strftime("%d/%m às %H:%M") %></p>
              </div>
            </div>
            <div class="flex items-center gap-6">
              <div class="text-right">
                <span class="block text-sm font-bold <%= score >= 70 ? 'text-[#34d399]' : 'text-[#fafafa]' %>"><%= score %>%</span>
                <span class="block text-xs text-[#71717a]">Pontuação</span>
              </div>
              <div class="opacity-0 group-hover:opacity-100 text-[#a78bfa] transition-all">
                <span class="material-symbols-outlined">chevron_right</span>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to group_quiz_path(activity), class: "group flex items-center justify-between p-4 bg-[#09090b] border border-[#27272a] rounded-lg hover:bg-[#121215] transition-colors cursor-pointer block" do %>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded bg-[#a78bfa]/10 border border-[#a78bfa]/30 flex items-center justify-center text-[#a78bfa]">
                <span class="material-symbols-outlined text-[20px]">group</span>
              </div>
              <div>
                <h4 class="text-sm font-bold text-[#fafafa]"><%= activity.title.presence || activity.subject.name %></h4>
                <p class="text-xs text-[#a1a1aa] mt-0.5">Sala em Grupo · <%= activity.updated_at.in_time_zone('America/Sao_Paulo').strftime("%d/%m às %H:%M") %></p>
              </div>
            </div>
            <div class="flex items-center gap-6">
              <div class="text-right">
                <span class="block text-sm font-bold text-[#fafafa]"><%= activity.group_participants.count %></span>
                <span class="block text-xs text-[#71717a]">Participantes</span>
              </div>
              <div class="opacity-0 group-hover:opacity-100 text-[#a78bfa] transition-all">
                <span class="material-symbols-outlined">chevron_right</span>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  </div>
</section>

<div class="h-4 w-full"></div>
