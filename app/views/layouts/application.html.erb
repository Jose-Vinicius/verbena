<!DOCTYPE html>
<html class="dark" lang="en">
  <head>
    <title><%= content_for(:title) || "Verbena Dashboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Verbena">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <!-- Fonts and Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <style>
      .material-symbols-outlined {
          font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      .icon-fill {
          font-variation-settings: 'FILL' 1, 'wght' 400;
      }
      
      ::-webkit-scrollbar { width: 8px; height: 8px; }
      ::-webkit-scrollbar-track { background: #09090b; }
      ::-webkit-scrollbar-thumb { background: #27272a; border-radius: 4px; }
      ::-webkit-scrollbar-thumb:hover { background: #52525b; }
    </style>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#09090b] text-[#fafafa] font-body h-screen flex overflow-hidden antialiased selection:bg-[#7c3aed] selection:text-[#ede9fe]">
    <% if user_signed_in? %>
      <%= render "shared/sidebar" %>
      
      <div class="flex-1 flex flex-col h-screen overflow-hidden relative">
        <!-- Mobile Top Navigation Fallback -->
        <header class="md:hidden flex justify-between items-center w-full h-16 px-6 border-b border-[#27272a] bg-[#09090b] z-20 flex-shrink-0">
          <div class="text-lg font-headline font-bold text-[#fafafa] tracking-tighter">verbena</div>
          <div class="flex items-center gap-4">
            <button class="text-[#a1a1aa] hover:text-[#fafafa] transition-colors">
              <span class="material-symbols-outlined">notifications</span>
            </button>
            <div class="w-8 h-8 rounded-full border border-[#27272a] overflow-hidden cursor-pointer hover:border-[#a78bfa] transition-colors">
              <span class="material-symbols-outlined mt-1">account_circle</span>
            </div>
          </div>
        </header>

        <!-- Main Scrollable Canvas -->
        <main class="flex-1 overflow-y-auto px-6 py-8 md:px-10 lg:px-16 lg:py-12 w-full max-w-7xl mx-auto">
          <% flash.each do |key, message| %>
            <div class="mb-4 p-4 rounded-lg text-sm font-medium <%= key == 'alert' ? 'bg-[#3b1111] text-[#fca5a5] border border-[#ef4444]/20' : 'bg-[#18181b] text-[#a78bfa] border border-[#a78bfa]/20' %>">
              <%= message %>
            </div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    <% else %>
      <div class="w-full h-full flex-1">
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
