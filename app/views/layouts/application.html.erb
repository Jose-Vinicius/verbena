<!DOCTYPE html>
<html class="dark" lang="en">
  <head>
    <title><%= content_for(:title) || "Verbena Dashboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Verbena">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <!-- Fonts and Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <style>
      .material-symbols-outlined {
          font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      .icon-fill {
          font-variation-settings: 'FILL' 1, 'wght' 400;
      }
      
      ::-webkit-scrollbar { width: 8px; height: 8px; }
      ::-webkit-scrollbar-track { background: #09090b; }
      ::-webkit-scrollbar-thumb { background: #27272a; border-radius: 4px; }
      ::-webkit-scrollbar-thumb:hover { background: #52525b; }
    </style>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#09090b] text-[#fafafa] font-body h-screen flex overflow-hidden antialiased selection:bg-[#7c3aed] selection:text-[#ede9fe]" data-controller="mobile-menu">
    <% if user_signed_in? %>
      <!-- Mobile Backdrop -->
      <div data-mobile-menu-target="backdrop" data-action="click->mobile-menu#close" class="hidden fixed inset-0 bg-black/60 z-40 md:hidden transition-opacity"></div>
      
      <%= render "shared/sidebar" %>
      
      <div class="flex-1 flex flex-col h-screen overflow-hidden relative">
        <!-- Mobile Top Navigation Fallback -->
        <header class="md:hidden flex justify-between items-center w-full h-16 px-6 border-b border-[#27272a] bg-[#09090b] z-20 flex-shrink-0">
          <div class="flex items-center gap-3">
            <button data-action="mobile-menu#toggle" class="text-[#a1a1aa] hover:text-[#fafafa] transition-colors flex items-center justify-center focus:outline-none">
              <span class="material-symbols-outlined text-[24px]">menu</span>
            </button>
            <div class="text-lg font-headline font-bold text-[#fafafa] tracking-tighter">verbena</div>
          </div>
          <div class="flex items-center gap-4">
            <div data-controller="dropdown" class="relative">
              <div data-action="click->dropdown#toggle" class="w-8 h-8 rounded-full border border-[#27272a] overflow-hidden cursor-pointer hover:border-[#a78bfa] transition-colors flex items-center justify-center bg-[#18181b]">
                <span class="material-symbols-outlined mt-1 text-[#fafafa]">account_circle</span>
              </div>
              
              <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-48 bg-[#0c0c0f] border border-[#27272a] rounded-lg shadow-xl z-50 py-1">
                <div class="px-4 py-2 border-b border-[#27272a] mb-1">
                  <p class="text-sm font-medium text-[#fafafa] truncate"><%= current_user.email %></p>
                </div>
                <%= button_to destroy_user_session_path, method: :delete, class: "w-full text-left px-4 py-2 text-sm text-[#fca5a5] hover:bg-[#18181b] transition-colors flex items-center gap-2" do %>
                  <span class="material-symbols-outlined text-[18px]">logout</span>
                  Sair do sistema
                <% end %>
              </div>
            </div>
          </div>
        </header>

        <!-- Main Scrollable Canvas -->
        <main class="flex-1 overflow-y-auto px-6 py-8 md:px-10 lg:px-16 lg:py-12 w-full max-w-7xl mx-auto">
          <% flash.each do |key, message| %>
            <div class="mb-4 p-4 rounded-lg text-sm font-medium <%= key == 'alert' ? 'bg-[#3b1111] text-[#fca5a5] border border-[#ef4444]/20' : 'bg-[#18181b] text-[#a78bfa] border border-[#a78bfa]/20' %>">
              <%= message %>
            </div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    <% else %>
      <div class="w-full h-full flex-1">
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
