<!DOCTYPE html>
<html class="dark" lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Verbena Quiz" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Fonts and Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    
    <style>
      .material-symbols-outlined {
          font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      .icon-fill {
          font-variation-settings: 'FILL' 1, 'wght' 400;
      }
      
      ::-webkit-scrollbar { width: 8px; height: 8px; }
      ::-webkit-scrollbar-track { background: #09090b; }
      ::-webkit-scrollbar-thumb { background: #27272a; border-radius: 4px; }
      ::-webkit-scrollbar-thumb:hover { background: #52525b; }
    </style>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#09090b] text-[#fafafa] font-body min-h-screen flex flex-col antialiased selection:bg-[#7c3aed] selection:text-[#ede9fe]">
    <!-- Public Header -->
    <header class="flex items-center justify-between w-full h-16 px-6 border-b border-[#27272a] bg-[#09090b] shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-[#18181b] border border-[#27272a] flex items-center justify-center overflow-hidden">
          <span class="material-symbols-outlined text-[#a78bfa] text-lg" style="font-variation-settings: 'FILL' 1;">menu_book</span>
        </div>
        <span class="text-lg font-headline font-bold text-[#fafafa] tracking-tighter">verbena</span>
      </div>
      <span class="text-xs text-[#71717a] font-mono uppercase tracking-wider">Questionário em Grupo</span>
    </header>

    <!-- Flash Messages -->
    <% flash.each do |key, message| %>
      <div class="mx-6 mt-4 p-4 rounded-lg text-sm font-medium <%= key == 'alert' ? 'bg-[#3b1111] text-[#fca5a5] border border-[#ef4444]/20' : 'bg-[#18181b] text-[#a78bfa] border border-[#a78bfa]/20' %>">
        <%= message %>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="py-4 text-center border-t border-[#27272a]">
      <p class="text-xs text-[#52525b]">Verbena Study Platform</p>
    </footer>
  </body>
</html>
