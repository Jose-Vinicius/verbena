<div class="flex-1 overflow-y-auto w-full p-4 md:p-8 flex justify-center items-start">
  <div class="w-full max-w-4xl relative">
    <!-- Progress Header -->
    <div class="mb-8 flex justify-between items-end pb-4 border-b border-[#27272a]">
      <div>
        <h2 class="text-xs font-semibold tracking-wider text-[#a1a1aa] uppercase mb-1"><%= @group_quiz.title %></h2>
        <h1 class="text-2xl font-headline font-bold text-[#fafafa]">Questão <%= @position %> de <%= @total %></h1>
      </div>
      <div class="flex items-center gap-2">
        <% progress = ((@position.to_f / @total) * 100).to_i %>
        <span class="text-sm font-medium text-[#a1a1aa]"><%= progress %>% Concluído</span>
        <div class="w-32 h-2 bg-[#121215] rounded-full overflow-hidden">
          <div class="h-full bg-[#a78bfa] transition-all duration-500 ease-out" style="width: <%= progress %>%;"></div>
        </div>
      </div>
    </div>

    <!-- Question Area -->
    <div class="bg-[#121215] rounded-lg border border-[#27272a] p-6 md:p-8 mb-6 shadow-sm">
      <div class="mb-6">
        <p class="text-lg md:text-xl font-body text-[#fafafa] leading-relaxed whitespace-pre-wrap">
          <%= @question.statement %>
        </p>
      </div>

      <!-- Options Grid -->
      <div class="grid grid-cols-1 gap-3">
        <% letters = ('A'..'E').to_a %>
        <% @question.options.each_with_index do |option_text, index| %>
          <%
            is_answered = @existing_answer.present?
            is_correct_option = (index == @question.correct_index)
            is_chosen_option = is_answered && (index == @existing_answer.chosen_index)

            button_classes = "group flex w-full text-left rounded-lg p-4 transition-colors focus:outline-none focus:ring-2 focus:ring-[#a78bfa]"

            if !is_answered
              button_classes += " bg-[#09090b] border border-[#27272a] hover:bg-[#18181b]"
            elsif is_correct_option
              button_classes += " bg-[#065f46]/10 border border-[#34d399] ring-1 ring-[#34d399]"
            elsif is_chosen_option && !is_correct_option
              button_classes += " bg-[#3b1111]/20 border border-[#ef4444] ring-1 ring-[#ef4444]"
            else
              button_classes += " bg-[#09090b] border border-[#27272a] opacity-70 cursor-not-allowed"
            end
          %>

          <% if is_answered %>
            <div class="<%= button_classes %>">
              <div class="flex items-center gap-4 w-full">
                <div class="flex-shrink-0 w-8 h-8 rounded-md bg-[#18181b] border border-[#27272a] flex items-center justify-center font-bold text-sm text-[#a1a1aa]">
                  <%= letters[index] %>
                </div>
                <span class="text-base text-[#fafafa] font-body text-left"><%= option_text %></span>

                <% if is_correct_option %>
                  <span class="material-symbols-outlined ml-auto text-[#34d399]">check_circle</span>
                <% elsif is_chosen_option %>
                  <span class="material-symbols-outlined ml-auto text-[#ef4444]">cancel</span>
                <% end %>
              </div>
            </div>
          <% else %>
            <%= form_with url: answer_public_quiz_question_path(@group_quiz.token, @position), method: :patch, class: "w-full" do %>
              <input type="hidden" name="chosen_index" value="<%= index %>">
              <button type="submit" class="<%= button_classes %> w-full">
                <div class="flex items-center gap-4 w-full">
                  <div class="flex-shrink-0 w-8 h-8 rounded-md bg-[#18181b] border border-[#27272a] flex items-center justify-center font-bold text-sm text-[#a1a1aa] group-hover:text-[#fafafa]">
                    <%= letters[index] %>
                  </div>
                  <span class="text-base text-[#fafafa] font-body text-left"><%= option_text %></span>
                </div>
              </button>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if @existing_answer.present? %>
      <!-- Explanation -->
      <div class="flex flex-col gap-4 mb-8">
        <% bg_border_class = @existing_answer.is_correct ? "bg-[#065f46]/20 border-[#34d399]/30" : "bg-[#3b1111]/20 border-[#ef4444]/30" %>
        <% text_icon_class = @existing_answer.is_correct ? "text-[#34d399]" : "text-[#ef4444]" %>
        <div class="p-4 rounded-lg border <%= bg_border_class %>">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined <%= text_icon_class %> mt-0.5">info</span>
            <div>
              <h3 class="text-sm font-bold <%= text_icon_class %> mb-1">
                <%= @existing_answer.is_correct ? 'Correto!' : 'Incorreto' %>
              </h3>
              <p class="text-sm text-[#a1a1aa] leading-relaxed whitespace-pre-wrap"><%= @question.explanation.presence || "A resposta correta é a Alternativa #{letters[@question.correct_index]}" %></p>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Action Footer -->
    <div class="flex justify-end items-center py-4 border-t border-[#27272a]">
      <% if @existing_answer.present? %>
        <% next_qq = @group_quiz.group_quiz_questions.where("position > ?", @position).order(:position).first %>
        <% if next_qq %>
          <%= link_to public_quiz_question_path(@group_quiz.token, next_qq.position), class: "bg-[#a78bfa] hover:bg-[#ede9fe] text-[#0a0012] font-bold py-2.5 px-6 rounded-md transition-colors flex items-center gap-2" do %>
            Próxima Questão
            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
          <% end %>
        <% else %>
          <%= button_to public_quiz_finish_path(@group_quiz.token), method: :post, class: "bg-[#34d399] hover:bg-[#6ee7b7] text-[#001a12] font-bold py-2.5 px-6 rounded-md transition-colors flex items-center gap-2" do %>
            Finalizar
            <span class="material-symbols-outlined text-[18px]">done_all</span>
          <% end %>
        <% end %>
      <% else %>
        <button class="bg-[#a78bfa] text-[#0a0012] font-bold py-2.5 px-6 rounded-md transition-colors flex items-center gap-2 opacity-50 cursor-not-allowed" disabled>
          Próxima Questão
          <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
        </button>
      <% end %>
    </div>
  </div>
</div>
