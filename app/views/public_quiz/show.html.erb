<div class="flex-1 flex items-center justify-center p-6">
  <div class="w-full max-w-md">
    <div class="bg-[#121215] border border-[#27272a] rounded-xl p-8 shadow-2xl shadow-black/50 text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#1e1e22] border border-[#27272a] mb-6 text-[#a78bfa]">
        <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">group</span>
      </div>

      <h1 class="text-2xl font-headline font-bold text-[#fafafa] mb-2"><%= @group_quiz.title %></h1>
      <p class="text-[#a1a1aa] text-sm mb-1"><%= @group_quiz.subject.name %> · <%= @group_quiz.questions_count %> questões</p>
      
      <% minutes_left = (@group_quiz.time_remaining / 60.0).ceil %>
      <div class="inline-flex items-center gap-1.5 text-xs text-[#a1a1aa] bg-[#09090b] border border-[#27272a] px-3 py-1 rounded-full mt-2 mb-8">
        <span class="material-symbols-outlined text-[14px]">schedule</span>
        <%= minutes_left %> min restantes
      </div>

      <%= form_with url: join_public_quiz_path(@group_quiz.token), method: :post, class: "space-y-4" do |f| %>
        <div>
          <%= f.text_field :name, class: "w-full bg-[#09090b] border border-[#27272a] rounded-lg py-3 px-4 text-[#fafafa] text-sm text-center focus:ring-2 focus:ring-[#a78bfa] focus:border-[#a78bfa] transition-colors placeholder:text-[#a1a1aa]/50", placeholder: "Seu nome", required: true, autofocus: true %>
        </div>
        <%= f.submit "Entrar na Sala", class: "w-full bg-[#a78bfa] text-[#0a0012] font-bold rounded-lg py-3.5 px-6 text-sm hover:bg-[#ede9fe] transition-all duration-200 cursor-pointer active:scale-[0.98]" %>
      <% end %>
    </div>
  </div>
</div>
