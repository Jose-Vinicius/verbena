<div class="flex-1 overflow-y-auto w-full p-4 md:p-8 flex justify-center items-start">
  <div class="w-full max-w-4xl">
    <!-- Header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#1e1e22] border border-[#27272a] mb-6 text-[#a78bfa]">
        <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">trophy</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-headline font-black text-[#fafafa] tracking-tight mb-2">Resultado</h1>
      <p class="text-[#a1a1aa]"><%= @group_quiz.title %></p>
    </div>

    <!-- Score Card -->
    <div class="bg-[#121215] border border-[#27272a] rounded-xl p-8 mb-8 text-center">
      <h3 class="text-[#a1a1aa] text-sm font-medium uppercase tracking-wider mb-2">Sua Pontuação</h3>
      <div class="flex items-baseline justify-center gap-4">
        <span class="text-6xl font-black text-[#fafafa] tracking-tighter">
          <%= @participant.correct_count %>
          <span class="text-3xl text-[#a1a1aa] font-bold">/<%= @group_quiz.questions_count %></span>
        </span>
        <% percentage = ((@participant.correct_count.to_f / @group_quiz.questions_count) * 100).to_i %>
        <span class="<%= percentage >= 70 ? 'text-[#34d399]' : (percentage >= 50 ? 'text-[#eab308]' : 'text-[#ef4444]') %> font-bold text-xl flex items-center gap-1">
          <span class="material-symbols-outlined"><%= percentage >= 50 ? 'trending_up' : 'trending_down' %></span>
          <%= percentage %>%
        </span>
      </div>

      <div class="flex justify-center gap-8 mt-6 pt-6 border-t border-[#27272a]">
        <div>
          <span class="block text-2xl font-bold text-[#34d399]"><%= @participant.correct_count %></span>
          <span class="text-xs text-[#a1a1aa] uppercase tracking-wider">Corretas</span>
        </div>
        <div>
          <span class="block text-2xl font-bold text-[#ef4444]"><%= @group_quiz.questions_count - @participant.correct_count %></span>
          <span class="text-xs text-[#a1a1aa] uppercase tracking-wider">Incorretas</span>
        </div>
      </div>
    </div>

    <!-- Ranking -->
    <div class="bg-[#121215] border border-[#27272a] rounded-xl overflow-hidden mb-8">
      <div class="px-6 py-4 border-b border-[#27272a] flex items-center gap-3">
        <span class="material-symbols-outlined text-[#a78bfa]">leaderboard</span>
        <h3 class="text-sm font-bold text-[#fafafa] uppercase tracking-wider">Ranking da Sala</h3>
      </div>

      <div class="divide-y divide-[#27272a]">
        <% @participants.each_with_index do |p, idx| %>
          <div class="flex items-center justify-between px-6 py-4 <%= p.token == @participant.token ? 'bg-[#a78bfa]/5' : '' %>">
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold
                <% if idx == 0 %>
                  bg-[#a78bfa]/20 text-[#a78bfa] border border-[#a78bfa]/30
                <% else %>
                  bg-[#18181b] text-[#a1a1aa] border border-[#27272a]
                <% end %>
              ">
                <%= idx + 1 %>
              </div>
              <span class="text-sm font-medium text-[#fafafa]">
                <%= p.name %>
                <%= "(Você)" if p.token == @participant.token %>
              </span>
            </div>
            <% score = ((p.correct_count.to_f / @group_quiz.questions_count) * 100).round %>
            <div class="text-right">
              <span class="text-sm font-bold <%= score >= 70 ? 'text-[#34d399]' : 'text-[#fafafa]' %>"><%= p.correct_count %>/<%= @group_quiz.questions_count %></span>
              <span class="block text-xs text-[#71717a]"><%= score %>%</span>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Review Answers -->
    <div class="mb-8">
      <h3 class="text-xl font-headline font-bold text-[#fafafa] mb-6 border-b border-[#27272a] pb-4">Revisão das Respostas</h3>
      <div class="space-y-4">
        <% letters = ('A'..'E').to_a %>
        <% @answers.each do |answer| %>
          <% if answer.is_correct %>
            <!-- Correct -->
            <div class="bg-[#121215] rounded-lg border border-[#27272a] p-6 flex flex-col gap-4">
              <div class="flex items-start justify-between gap-4">
                <div class="flex gap-4">
                  <div class="w-8 h-8 rounded-full bg-[#065f46]/20 text-[#34d399] flex items-center justify-center shrink-0 border border-[#34d399]/30">
                    <span class="material-symbols-outlined text-[18px]">check</span>
                  </div>
                  <div class="w-full">
                    <h4 class="text-[#fafafa] font-medium text-lg leading-snug mb-3 whitespace-pre-wrap"><%= answer.question.statement %></h4>
                    <div class="space-y-3 w-full">
                      <div class="flex items-center gap-3">
                        <span class="text-xs text-[#a1a1aa] w-16 uppercase tracking-wider">Sua Resposta</span>
                        <div class="flex-1 p-3 rounded bg-[#065f46]/10 border border-[#34d399]/30 text-[#34d399] font-medium text-sm flex items-center justify-between">
                          <%= answer.question.options[answer.chosen_index] %>
                          <span class="material-symbols-outlined text-[16px]">check</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <span class="text-xs font-bold text-[#34d399] uppercase tracking-wider bg-[#065f46]/20 px-2 py-1 rounded shrink-0">Correto</span>
              </div>
            </div>
          <% else %>
            <!-- Incorrect -->
            <div class="bg-[#121215] rounded-lg border border-[#27272a] p-6 flex flex-col gap-4">
              <div class="flex items-start justify-between gap-4">
                <div class="flex gap-4">
                  <div class="w-8 h-8 rounded-full bg-[#3b1111]/40 text-[#ef4444] flex items-center justify-center shrink-0 border border-[#ef4444]/30">
                    <span class="material-symbols-outlined text-[18px]">close</span>
                  </div>
                  <div class="w-full">
                    <h4 class="text-[#fafafa] font-medium text-lg leading-snug mb-3 whitespace-pre-wrap"><%= answer.question.statement %></h4>
                    <div class="space-y-3 w-full">
                      <div class="flex items-center gap-3">
                        <span class="text-xs text-[#a1a1aa] w-16 uppercase tracking-wider">Sua Resposta</span>
                        <div class="flex-1 p-3 rounded bg-[#3b1111]/20 border border-[#ef4444]/30 text-[#ef4444] font-medium text-sm flex items-center justify-between">
                          <%= answer.question.options[answer.chosen_index] %>
                          <span class="material-symbols-outlined text-[16px]">close</span>
                        </div>
                      </div>
                      <div class="flex items-center gap-3">
                        <span class="text-xs text-[#a1a1aa] w-16 uppercase tracking-wider">Correta</span>
                        <div class="flex-1 p-3 rounded bg-[#065f46]/10 border border-[#34d399]/30 text-[#34d399] font-medium text-sm flex items-center justify-between">
                          <%= answer.question.options[answer.question.correct_index] %>
                          <span class="material-symbols-outlined text-[16px]">check</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <span class="text-xs font-bold text-[#ef4444] uppercase tracking-wider bg-[#3b1111]/20 px-2 py-1 rounded shrink-0">Incorreto</span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
