<!-- Header & Search -->
<header class="px-10 py-8 border-b border-[#27272a] bg-[#09090b] shrink-0 z-10">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-end justify-between mb-6">
      <div>
        <h2 class="text-3xl font-headline font-bold text-[#fafafa] tracking-tight mb-1">Matérias</h2>
        <p class="text-[#a1a1aa] text-sm">Gerencie seus domínios e áreas de estudo.</p>
      </div>
      <div class="flex gap-4">
        <div class="text-sm font-mono text-[#a1a1aa] bg-[#121215] px-3 py-1.5 rounded border border-[#27272a] flex items-center">
          Total: <%= @subjects.size %>
        </div>
        <%= link_to new_subject_path, class: "flex items-center gap-2 bg-[#a78bfa] text-[#0a0012] px-4 py-1.5 rounded text-sm font-bold hover:bg-[#c4b5fd] transition-colors" do %>
          <span class="material-symbols-outlined text-[18px]">add</span>
          Nova Matéria
        <% end %>
      </div>
    </div>
  </div>
</header>

<!-- Scrollable Content -->
<div class="flex-1 overflow-y-auto px-10 py-8">
  <div class="max-w-5xl mx-auto">
    <% if @subjects.empty? %>
      <div class="text-center py-20 bg-[#121215] border border-[#27272a] rounded-xl">
        <span class="material-symbols-outlined text-6xl text-[#27272a] mb-4">category</span>
        <h3 class="text-xl font-headline text-[#fafafa] font-bold">Nenhuma matéria cadastrada</h3>
        <p class="text-[#a1a1aa] mt-2">Crie sua primeira matéria para começar a organizar suas questões.</p>
        <%= link_to new_subject_path, class: "inline-flex items-center gap-2 bg-[#a78bfa] text-[#0a0012] font-bold py-2.5 px-6 rounded-lg mt-6 hover:bg-[#c4b5fd] transition-colors" do %>
          <span class="material-symbols-outlined">add</span> Criar Matéria
        <% end %>
      </div>
    <% else %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @subjects.each do |subject| %>
          <%= link_to questions_path(subject_id: subject.id), class: "group relative bg-[#121215] border border-[#27272a] rounded-xl p-6 flex flex-col justify-between hover:border-[#52525b] hover:bg-[#18181b] transition-all duration-300 cursor-pointer block" do %>
            <div class="absolute inset-0 bg-gradient-to-br to-transparent opacity-0 group-hover:opacity-10 transition-opacity rounded-xl pointer-events-none" style="--tw-gradient-from: <%= subject.color || '#a78bfa' %>; --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, transparent);"></div>
            <div>
              <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 rounded bg-[#09090b] border border-[#27272a] flex items-center justify-center group-hover:scale-110 transition-transform shadow-sm" style="color: <%= subject.color || '#a78bfa' %>;">
                  <% if subject.icon.present? && subject.icon.length <= 2 %>
                    <span class="text-xl"><%= subject.icon %></span>
                  <% else %>
                    <span class="material-symbols-outlined text-xl" style="font-variation-settings: 'FILL' 1;"><%= subject.icon.presence || 'folder_open' %></span>
                  <% end %>
                </div>
                <div class="flex gap-2">
                  <object><a href="<%= edit_subject_path(subject) %>" class="w-8 h-8 flex items-center justify-center rounded-lg bg-[#09090b] border border-[#27272a] text-[#a1a1aa] hover:text-[#fafafa] hover:border-[#52525b] transition-colors relative z-20 pointer-events-auto" title="Editar Matéria"><span class="material-symbols-outlined text-sm">edit</span></a></object>
                  <span class="text-xs font-mono text-[#a1a1aa] bg-[#09090b] px-2 py-1.5 rounded border border-[#27272a] flex items-center">
                    <%= subject.questions.size %> Questões
                  </span>
                </div>
              </div>
              <h3 class="text-lg font-headline font-bold text-[#fafafa] mb-1 transition-colors" style="--tw-group-hover-color: <%= subject.color || '#c4b5fd' %>;"><span class="group-hover:!text-[var(--tw-group-hover-color)] transition-colors"><%= subject.name %></span></h3>
            </div>
            <div class="mt-4 pt-4 border-t border-[#27272a] flex justify-between items-center relative z-10">
              <span class="text-xs text-[#71717a]">Criado em <%= subject.created_at.strftime("%d/%m/%Y") %></span>
              <span class="material-symbols-outlined opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all text-sm" style="color: <%= subject.color || '#a78bfa' %>;">arrow_forward</span>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
    
    <!-- Spacer for scrolling -->
    <div class="h-12"></div>
  </div>
</div>
